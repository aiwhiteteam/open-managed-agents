# Local default. In staging/production, point this at a managed Postgres instance.
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/open_managed_agents
DATABASE_URL=sqlite+aiosqlite:///./open_managed_agents.db
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_USE_RESPONSES=true
OMA_API_KEYS=
OMA_REQUIRE_BETA_HEADER=true
OMA_REQUIRE_ANTHROPIC_VERSION_HEADER=true
OMA_RUNTIME_BACKEND=auto
OMA_DEFAULT_MODEL_PROVIDER=openai
OMA_DEFAULT_OPENAI_MODEL=gpt-5.5
OMA_DEFAULT_WORKSPACE_ID=wrkspc_default
# Optional self-hosted mapping for multiple API keys. Hosted/private layers should
# inject an AuthProvider instead of relying on env-only workspace mapping.
OMA_API_KEY_WORKSPACES={}
OMA_MAX_FILE_UPLOAD_BYTES=52428800
OMA_MAX_SKILL_ARCHIVE_BYTES=26214400

# OpenAI-compatible model providers. These are routed through OpenAI Agents SDK
# OpenAIProvider(base_url=..., use_responses=false).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-pro
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_DEFAULT_MODEL=MiniMax-M3
# JSON object for additional OpenAI-compatible providers, for example:
# {"moonshot":{"api_key_env":"MOONSHOT_API_KEY","base_url":"https://api.moonshot.ai/v1","default_model":"kimi-k2"}}
OMA_OPENAI_COMPATIBLE_PROVIDERS={}

# S3-compatible object storage stores uploaded files, skill archives,
# future session artifacts, and generated bundles. Cloudflare R2 is just one
# compatible backend; point S3_ENDPOINT_URL at the R2 S3 endpoint when using R2.
OMA_STORAGE_BACKEND=database
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=
S3_REGION=auto

# Legacy compatibility aliases. Prefer S3_* for new deployments.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_FILES_BUCKET_NAME=
R2_FILES_URL=

APP_ENV=local
LOG_LEVEL=INFO
SENTRY_DSN=

# Local default. In staging/production, point this at a managed Postgres instance.
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/open_managed_agents
DATABASE_URL=sqlite+aiosqlite:///./open_managed_agents.db

OPENAI_API_KEY=
OMA_DEFAULT_OPENAI_MODEL=gpt-5.5

OMA_API_KEYS=
OMA_PUBLIC_BASE_URL=https://example.invalid
# Optional extra shared token for self-hosted work queue routes.
OMA_WORKER_TOKEN=

# Optional AES-256-GCM at-rest encryption for vault credential secrets.
# Without a key, secrets are stored as plaintext in the database.
# Generate one with:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
OMA_ENCRYPTION_KEY=

# S3-compatible object storage stores uploaded files, skill archives,
# future session artifacts, and generated bundles. Cloudflare R2 is just one
# compatible backend; point S3_ENDPOINT_URL at the R2 S3 endpoint when using R2.
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=
S3_REGION=auto
